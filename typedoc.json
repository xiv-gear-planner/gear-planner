{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "packages/xivmath",
    "packages/core",
  ],
  "exclude": [
    "**/scripts/test/**/*.ts"
  ],
  "excludePrivate": false,
  "readme": "API_DOC.md",
  "out": "packages/frontend/dist/docs",
  "name": "Xivgear API Documentation",
  "includeVersion": true,
  "validation": {
    "invalidLink": true,
    "notExported": true
  },
  "useTsLinkResolution": true,
  "skipErrorChecking": false
}
