{
  "$schema": "https://typedoc.org/schema.json",
  "tsconfig": "tsconfig.typedoc.json",
  "entryPoints": ["src/scripts/**/*.ts"],
  "exclude": [
    "**/scripts/test/**/*",
    "**/test/**/*",
    "**/*.test.ts",
    "**/*tests.ts"
  ],
  "excludePrivate": false,
  "readme": "none",
  "includeVersion": true,
  "useTsLinkResolution": true,

  "validation": {
    "invalidLink": true,
    "notExported": true
  }
}
