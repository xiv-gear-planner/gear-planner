{
  "name": "@xivgear/backend-resolver",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "build": "pnpm run generate-schemas && tsc --build",
    "buildprod": "pnpm run generate-schemas && tsc --build",
    "generate-schemas": "pnpm exec typescript-json-schema \"src/api-registry.ts\" ApiSchemas --out schemas/api-schemas.json --id ApiSchemas --topRef --required --expose=all --ignoreErrors --typeCheck",
    "test": "ts-mocha --parallel=true \"src/test/**/*.ts\""
  },
  "dependencies": {
    "@fastify/cors": "8.5.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^1.10.1",
    "@types/chai": "^4.3.20",
    "@xivgear/core": "workspace:*",
    "@xivgear/xivmath": "workspace:*",
    "chai": "^4.5.0",
    "fastify": "^4.29.1",
    "fastify-ip": "1.1.0",
    "fastify-web-response": "^0.1.2",
    "global-jsdom": "^25.0.0",
    "isomorphic-fetch": "^3.0.0",
    "jsdom": "^25.0.1",
    "node-fetch-cache": "^4.1.2",
    "npm-bundle": "^3.0.3"
  },
  "devDependencies": {
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/jsdom": "^21.1.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.18",
    "ts-json-schema-generator": "^1.2.0",
    "ts-mocha": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript-json-schema": "^0.67.1"
  }
}
