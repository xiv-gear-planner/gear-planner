{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "packages/xivmath",
    "packages/util",
    "packages/core",
    "packages/sims",
    "packages/frontend",
    "packages/common-ui",
    "packages/i18n",
    "packages/data-api-client",
    "packages/account-service-client",
    "packages/user-data-client"
  ],
  "exclude": [
    "**/scripts/test/**/*.ts"
  ],
  "excludePrivate": false,
  "readme": "API_DOC.md",
  "out": "packages/frontend/dist/docs",
  "name": "Xivgear API Documentation",
  "includeVersion": true,
  "validation": {
    "invalidLink": true,
    "notExported": true
  },
  "useTsLinkResolution": true,
  "skipErrorChecking": true
}
